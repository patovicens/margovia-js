# Margovia SDK examples
MARGOVIA_API_KEY=mg_test_xxx

# Optional. Leave unset to use Margovia Cloud when MARGOVIA_API_KEY is configured.
# Set this only for local development, self-hosting, or a compatible receiver.
MARGOVIA_BASE_URL=http://localhost:4010

# Optional verbose SDK logging.
MARGOVIA_DEBUG=1

# Provider keys used by examples.
OPENAI_API_KEY=sk_xxx
ANTHROPIC_API_KEY=sk-ant-xxx
