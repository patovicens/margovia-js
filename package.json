{
  "name": "@margovia/sdk",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/patovicens/margovia-js.git"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "examples", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30",
    "openai": ">=4"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  }
}
